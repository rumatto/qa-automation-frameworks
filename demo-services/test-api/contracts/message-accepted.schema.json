{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://rumatto.github.io/qa-automation-frameworks/contracts/message-accepted.schema.json",
  "title": "Accepted message response",
  "type": "object",
  "additionalProperties": false,
  "required": ["status", "messageId", "submittedAt", "echo"],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["accepted"]
    },
    "messageId": {
      "type": "string",
      "enum": ["msg-001"]
    },
    "submittedAt": {
      "type": "string",
      "enum": ["2026-04-25T12:00:00Z"]
    },
    "echo": {
      "type": "object",
      "additionalProperties": false,
      "required": ["email", "message"],
      "properties": {
        "email": {
          "type": "string",
          "pattern": "^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$"
        },
        "message": {
          "type": "string",
          "minLength": 10
        }
      }
    }
  }
}
