{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://rumatto.github.io/qa-automation-frameworks/contracts/error-response.schema.json",
  "title": "Error response",
  "type": "object",
  "additionalProperties": false,
  "required": ["status", "message"],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["error"]
    },
    "message": {
      "type": "string",
      "minLength": 1
    }
  }
}
